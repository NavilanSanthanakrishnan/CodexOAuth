# If set, requests to the local API must include:
# Authorization: Bearer <this value>
CODEX_OAUTH_API_KEY=

# Direct Codex OAuth API default model.
CODEX_OAUTH_MODEL=gpt-5.4

# Optional private OAuth token cache. Create it with:
# ./CodexOAuth --login
CODEX_OAUTH_AUTH_FILE=~/.codex-oauth/auth.json

# Optional fallback token source. The API uses this only when no private
# ~/.codex-oauth/auth.json exists.
CODEX_OAUTH_CODEX_CLI_AUTH_FILE=~/.codex/auth.json
